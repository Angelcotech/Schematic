{
  "name": "claude-schematic",
  "version": "0.2.1",
  "description": "Ask Claude Code to draw live architecture diagrams of your repo. Interactive canvas, MCP tools, and right-click actions for blast-radius and audit queries.",
  "keywords": [
    "claude-code",
    "claude",
    "architecture",
    "diagram",
    "canvas",
    "mcp",
    "hooks",
    "typescript"
  ],
  "license": "MIT",
  "author": "David Alan Brown (Angelco)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Angelcotech/Schematic.git"
  },
  "homepage": "https://github.com/Angelcotech/Schematic#readme",
  "bugs": "https://github.com/Angelcotech/Schematic/issues",
  "type": "module",
  "bin": {
    "schematic": "./dist/cli/index.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "daemon": "node dist/daemon/bin.js",
    "cli": "node dist/cli/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chokidar": "^4.0.1",
    "dagre": "^0.8.5",
    "ignore": "^6.0.2",
    "typescript": "^5.5.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5.0"
  }
}